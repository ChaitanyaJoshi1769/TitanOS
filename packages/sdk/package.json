  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "prettier": "^3.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  }
}
